{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:paul-schick.com)",
      "WebFetch(domain:www.groff.dev)",
      "Bash(/tmp/comparison.md:*)",
      "Read(//tmp/**)",
      "Bash(cargo run:*)",
      "Bash(cargo build:*)",
      "Bash(cargo test:*)",
      "Bash(cargo update:*)",
      "Bash(git add:*)",
      "Bash(jq:*)",
      "Bash(git commit:*)",
      "WebFetch(domain:crates.io)",
      "Bash(RUST_LOG=debug ./target/debug/nanobot-rs agent:*)",
      "Bash(RUST_LOG=debug ./target/release/nanobot-rs agent:*)",
      "Bash(curl:*)",
      "Bash(RUST_LOG=info ./target/release/nanobot-rs agent:*)",
      "Bash(echo:*)",
      "Bash(nc:*)",
      "Bash(cargo check:*)",
      "Bash(wc:*)",
      "Bash(cat:*)",
      "Bash(cargo:*)",
      "Bash(find src/session -name \"*.rs\" -exec wc -l {} + | tail -1)",
      "Bash(find docs:*)",
      "Bash(ls -1 docs/SESSION*.md CHANGELOG_SESSION.md SESSION_IMPLEMENTATION_COMPLETE.md 2>/dev/null | wc -l)",
      "Bash(ls -1 src/session/*.rs | wc -l)",
      "Bash(ls -la src/session/*.rs)",
      "Bash(grep -v \"^$\")",
      "WebFetch(domain:docs.anthropic.com)"
    ]
  }
}
